# Override the URL that smoke_tests.sh and pytest target.
# BASE_URL=http://localhost:8080

# If you already have a Postgres instance running from ch02 and want
# the catalog service to use it instead of the bundled one, set:
# DATABASE_URL=postgresql://catalog:catalog@localhost:5432/catalog

# Required for the AI-powered /describe endpoint (section 3.7.3).
# Get a key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-key-here
